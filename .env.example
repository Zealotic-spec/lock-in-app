# ─── Root .env.example ────────────────────────────────────────────────────
# Copy each block into client/.env and server/.env respectively (or use as
# a reference when setting Environment Variables in the Vercel dashboard).
# Real secrets never get committed — only .env.example files are tracked.

# ── Database (Supabase Postgres) ───────────────────────────────────────────
# Pooled connection (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.nuxhyxfatzjkifogjjjs:Nurisss_love3@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"
# Direct connection (port 5432) — required by Prisma Migrate.
DIRECT_URL="postgresql://postgres:Nurisss_love3@db.nuxhyxfatzjkifogjjjs.supabase.co:5432/postgres"

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS in production.
CORS_ORIGIN="http://localhost:5173"

# ── Client (Vite, must be prefixed VITE_) ───────────────────────────────────
# Leave unset in local dev — Vite proxies /api to localhost:4000 automatically.
VITE_API_URL=
