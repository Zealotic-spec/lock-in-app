# Postgres connection string (Supabase: Project Settings → Database → Connection string → URI).
# Use the *pooled* (port 6543, pgbouncer) string for DATABASE_URL on serverless, and the
# direct (port 5432) string for DIRECT_URL — Prisma needs the direct one for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Secret used to sign JWT access tokens. Generate your own, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Comma-separated list of allowed origins for CORS in production.
CORS_ORIGIN="http://localhost:5173"

PORT=4000
NODE_ENV=development
